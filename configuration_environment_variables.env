# File: configuration_environment_variables.env
# Functional Designation: system_parameter_injection_matrix
# Status: CTO Verified - UNIX Compliant

# 1. SECRETS (Sourced from local enclave)
source $HOME/.gemini_vault
source $HOME/.github_vault
export GH_TOKEN="$GITHUB_PAT"

# 2. ARCHITECTURAL PATHS (Termux-Internal)
export ENTERPRISE_ROOT="$HOME/sol_savage_enterprise"
export ENGINE_ROOT="$ENTERPRISE_ROOT/sol_savage_engine"

# 3. DATA PATHS (For Sequence 04: Technical Wash)
export LEDGER_FILE_PATH="$ENTERPRISE_ROOT/ledger/sol_savage_ledger.csv"
export RAW_INGESTION_PATH="$ENTERPRISE_ROOT/01_receiving/raw"
export INVENTORY_PHOTOS_PATH="$ENTERPRISE_ROOT/01_receiving/inventory_photos"

# 4. HARDWARE BRIDGES (S25 Ultra Storage)
export STAGING_BRIDGE="/sdcard/Download/sol_savage_engine"
export CAMERA_DCIM_PATH="/sdcard/DCIM/Camera" 

# 5. MSI ENDPOINT (Catcher's Mitt)
export MSI_ENDPOINT="https://script.google.com/macros/s/AKfycbx8zHb8Ec5lZbzlJX7Xdyo3_r_kLrhLNR0HhvSMBQbuUh_nliphJpxKU2eQR9eG5iG3/exec"

# 6. SYSTEM INTEGRITY CHECK
if [ ! -d "$ENTERPRISE_ROOT" ]; then
    echo "[!] Initializing Enterprise Directory Structure..."
    mkdir -p "$ENTERPRISE_ROOT"/{01_receiving/raw,01_receiving/inventory_photos,ledger,sol_savage_engine/scripts}
fi
